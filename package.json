    "@supabase/supabase-js": "^2.49.1",
    "chromadb": "^3.1.4",
    "dotenv": "^16.4.5",
    "fast-xml-parser": "^4.5.0",
    "slugify": "^1.6.6",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
